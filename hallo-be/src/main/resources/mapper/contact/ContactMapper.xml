<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hallo.contact.mapper.ContactMapper">
        <resultMap id="contactResultMap" type="com.hallo.contact.mapper.model.ContactModel">
                <id column="c_id" property="id" />
                <result column="c_account" property="account" />
                <result column="c_nickname" property="nickname" />
                <result column="c_avatar" property="avatar" />
        </resultMap>

        <resultMap id="groupResultMap" type="com.hallo.contact.mapper.model.GroupModel">
                <id column="group_id" property="id" />
                <result column="group_name" property="name" />
                <result column="group_avatar" property="avatar" />
                <result column="group_description" property="description" />
        </resultMap>

        <select id="getFriendList" resultMap="contactResultMap"> 
                SELECT
                        c_id, 
                        c_account,
                        c_nickname,
                        c_avatar,
                        c_mail
                FROM
                        t_user 
                WHERE c_id IN 
                        (SELECT 
                                uf.c_friend_id
                        FROM t_user_friend as uf
                        LEFT JOIN t_user as u ON u.c_id = uf.c_user_id
                        WHERE u.c_id = #{userId} )
                ORDER BY
                        c_nickname ASC
        </select>

        <select id="getGroupList" resultMap="groupResultMap">
                SELECT 
                        g.c_id AS group_id,
                        g.c_name AS group_name,
                        g.c_avatar AS group_avatar,
                        g.c_description AS group_description
                FROM 
                        t_user_group ug
                INNER JOIN t_group g ON ug.c_group_id = g.c_id
                WHERE 
                        ug.c_user_id = #{userId}
                ORDER BY 
                        g.c_name ASC
        </select>
</mapper>